# ─── API Server — Vertex OS ──────────────────────────────────────────────────

# Banco de dados PostgreSQL (obrigatório)
# Exemplo: postgresql://usuario:senha@host:5432/vertexos
DATABASE_URL=

# Porta em que o servidor escuta (padrão: 8080)
PORT=8080

# Origens permitidas pelo CORS, separadas por vírgula.
# Deixe vazio para permitir qualquer origem (apenas em desenvolvimento).
# Exemplo em produção: https://vertexos.com,https://www.vertexos.com
CORS_ORIGINS=

# Ambiente Node.js
NODE_ENV=production
